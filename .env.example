# Environment variables for RepoLens
# 复制此文件为 .env 并填入你的值

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/repolens

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333

# GitHub (可选，用于 Private 仓库)
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Analysis limits
MAX_REPO_SIZE_MB=500
MAX_FILES=10000
MAX_TOKEN_BUDGET=200000
